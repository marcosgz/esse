#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'
set -vx

RUBY_IMAGE="ruby:2.7"
BUNDLER_VERSION="2.3.26"

docker run --rm -v "$(pwd)":/app -w /app "$RUBY_IMAGE" \
  bash -c "gem install bundler:$BUNDLER_VERSION --no-document && bundle install"

for gemfile in gemfiles/Gemfile.elasticsearch-*.x gemfiles/Gemfile.opensearch-*.x; do
  [ -f "$gemfile" ] || continue
  [[ "$gemfile" == *.lock ]] && continue
  docker run --rm -v "$(pwd)":/app -w /app \
    -e BUNDLE_GEMFILE="$gemfile" \
    "$RUBY_IMAGE" \
    bash -c "gem install bundler:$BUNDLER_VERSION --no-document && bundle install"
done
